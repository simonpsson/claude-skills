{
  "_comment": "Line + Clustered Column Combo — Columns for values, line for trend",
  "$schema": "https://developer.microsoft.com/json-schemas/fabric/item/report/definition/visualContainer/2.7.0/schema.json",
  "name": "v05ComboSalesTrend",
  "position": {
    "x": 30,
    "y": 250,
    "z": 2000,
    "width": 600,
    "height": 400,
    "tabOrder": 4
  },
  "visual": {
    "visualType": "lineClusteredColumnComboChart",
    "query": {
      "queryState": {
        "Category": {
          "projections": [
            {
              "field": {
                "Column": {
                  "Expression": {
                    "SourceRef": {
                      "Entity": "DimDate"
                    }
                  },
                  "Property": "Month"
                }
              },
              "queryRef": "DimDate.Month",
              "nativeQueryRef": "Month"
            }
          ]
        },
        "ColumnY": {
          "projections": [
            {
              "field": {
                "Measure": {
                  "Expression": {
                    "SourceRef": {
                      "Entity": "_Measures"
                    }
                  },
                  "Property": "Total Sales"
                }
              },
              "queryRef": "_Measures.Total Sales",
              "nativeQueryRef": "Total Sales"
            }
          ]
        },
        "LineY": {
          "projections": [
            {
              "field": {
                "Measure": {
                  "Expression": {
                    "SourceRef": {
                      "Entity": "_Measures"
                    }
                  },
                  "Property": "Profit Margin %"
                }
              },
              "queryRef": "_Measures.Profit Margin %",
              "nativeQueryRef": "Profit Margin %"
            }
          ]
        }
      }
    },
    "drillFilterOtherVisuals": true
  }
}