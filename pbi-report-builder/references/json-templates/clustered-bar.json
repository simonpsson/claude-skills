{
  "_comment": "Clustered Bar Chart — Horizontal bars with category and value",
  "$schema": "https://developer.microsoft.com/json-schemas/fabric/item/report/definition/visualContainer/2.7.0/schema.json",
  "name": "v03BarByRegion",
  "position": {
    "x": 30,
    "y": 250,
    "z": 2000,
    "width": 600,
    "height": 400,
    "tabOrder": 2
  },
  "visual": {
    "visualType": "clusteredBarChart",
    "query": {
      "queryState": {
        "Category": {
          "projections": [
            {
              "field": {
                "Column": {
                  "Expression": {
                    "SourceRef": {
                      "Entity": "DimGeography"
                    }
                  },
                  "Property": "Region"
                }
              },
              "queryRef": "DimGeography.Region",
              "nativeQueryRef": "Region"
            }
          ]
        },
        "Y": {
          "projections": [
            {
              "field": {
                "Measure": {
                  "Expression": {
                    "SourceRef": {
                      "Entity": "_Measures"
                    }
                  },
                  "Property": "Total Sales"
                }
              },
              "queryRef": "_Measures.Total Sales",
              "nativeQueryRef": "Total Sales"
            }
          ]
        }
      }
    },
    "drillFilterOtherVisuals": true
  }
}